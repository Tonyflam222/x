# OpenChat Plugin Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
# Choose your Internet Computer network
# Options: local, testnet, mainnet
OPENCHAT_NETWORK=mainnet

# =============================================================================
# CANISTER IDs
# =============================================================================
# OpenChat canister IDs for your chosen network
# Get the latest IDs from OpenChat documentation

# Mainnet Canister IDs (verify these are current)
OPENCHAT_USER_INDEX_CANISTER=rdmx6-jaaaa-aaaah-qcaiq-cai
OPENCHAT_GROUP_INDEX_CANISTER=bkyz2-fmaaa-aaaah-qcaiq-cai
OPENCHAT_NOTIFICATIONS_CANISTER=iywa7-ayaaa-aaaah-qcaiq-cai
OPENCHAT_ONLINE_USERS_CANISTER=dxhxa-iyaaa-aaaah-qcaiq-cai
OPENCHAT_PROPOSALS_CANISTER=rqch6-3yaaa-aaaah-qcaiq-cai
OPENCHAT_REGISTRY_CANISTER=rdmx6-jaaaa-aaaah-qcaiq-cai
OPENCHAT_INTERNET_IDENTITY_CANISTER=rdmx6-jaaaa-aaaah-qcaiq-cai

# Local Development Canister IDs (uncomment for local development)
# OPENCHAT_USER_INDEX_CANISTER=rrkah-fqaaa-aaaaa-aaaaq-cai
# OPENCHAT_GROUP_INDEX_CANISTER=rno2w-sqaaa-aaaaa-aaacq-cai
# OPENCHAT_NOTIFICATIONS_CANISTER=rdmx6-jaaaa-aaaaa-aaaaq-cai
# OPENCHAT_ONLINE_USERS_CANISTER=rrkah-fqaaa-aaaaa-aaaaq-cai
# OPENCHAT_PROPOSALS_CANISTER=rno2w-sqaaa-aaaaa-aaacq-cai
# OPENCHAT_REGISTRY_CANISTER=rdmx6-jaaaa-aaaaa-aaaaq-cai
# OPENCHAT_INTERNET_IDENTITY_CANISTER=rrkah-fqaaa-aaaaa-aaaaq-cai

# =============================================================================
# BOT CONFIGURATION
# =============================================================================
# Bot identity and profile settings

# Bot username (required)
# 3-20 characters, letters/numbers/underscores only
OPENCHAT_BOT_USERNAME=my_eliza_bot

# Bot display name (optional)
OPENCHAT_BOT_DISPLAY_NAME="Eliza AI Assistant"

# Bot bio/description (optional)
OPENCHAT_BOT_BIO="An AI assistant powered by ElizaOS. I can help answer questions, provide information, and engage in conversations. Feel free to message me anytime!"

# Bot avatar URL (optional)
OPENCHAT_BOT_AVATAR_URL=https://example.com/bot-avatar.png

# Maximum message length (default: 1000, max: 4000)
OPENCHAT_MAX_MESSAGE_LENGTH=1000

# =============================================================================
# BEHAVIOR SETTINGS
# =============================================================================
# Control how your bot behaves

# Automatically join public groups when mentioned/invited (true/false)
OPENCHAT_AUTO_JOIN_GROUPS=false

# Respond to direct messages automatically (true/false)
OPENCHAT_RESPOND_TO_DMS=true

# Respond when mentioned in group chats (true/false)
OPENCHAT_RESPOND_TO_MENTIONS=true

# =============================================================================
# RATE LIMITING
# =============================================================================
# Prevent your bot from being flagged as spam

# Maximum messages per minute per chat
OPENCHAT_RATE_LIMIT_PER_MINUTE=10

# Maximum messages per hour per chat
OPENCHAT_RATE_LIMIT_PER_HOUR=100

# Maximum concurrent conversations
OPENCHAT_MAX_CONCURRENT_CHATS=50

# =============================================================================
# IDENTITY CONFIGURATION
# =============================================================================
# Choose ONE of these methods for bot identity

# Method 1: Private Key (hex string)
# OPENCHAT_PRIVATE_KEY=308187020100301306072a8648ce3d020106082a8648ce3d030107046d306b0201010420...

# Method 2: Seed Phrase (12 or 24 words)
# OPENCHAT_SEED_PHRASE="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# Method 3: PEM File Path
# OPENCHAT_PEM_FILE=/path/to/your/identity.pem

# =============================================================================
# WEBHOOK CONFIGURATION (OPTIONAL)
# =============================================================================
# Real-time event notifications

# Webhook URL for receiving events
# OPENCHAT_WEBHOOK_URL=https://your-server.com/openchat-webhook

# Webhook secret for signature verification
# OPENCHAT_WEBHOOK_SECRET=your-webhook-secret-here

# Events to subscribe to (comma-separated)
# Options: message, message_edited, message_deleted, user_joined, user_left, chat_updated
# OPENCHAT_WEBHOOK_EVENTS=message,user_joined,user_left

# =============================================================================
# DEBUGGING AND LOGGING
# =============================================================================
# Development and troubleshooting options

# Enable debug logging (true/false)
OPENCHAT_DEBUG=false

# Log level (error, warn, info, debug)
OPENCHAT_LOG_LEVEL=info

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================
# Advanced configuration options

# Polling interval for message checking (milliseconds)
# OPENCHAT_POLLING_INTERVAL=5000

# Connection timeout (milliseconds)
# OPENCHAT_CONNECTION_TIMEOUT=30000

# Retry attempts for failed requests
# OPENCHAT_RETRY_ATTEMPTS=3

# Retry delay (milliseconds)
# OPENCHAT_RETRY_DELAY=1000

# =============================================================================
# EXAMPLES FOR DIFFERENT ENVIRONMENTS
# =============================================================================

# Local Development Example:
# OPENCHAT_NETWORK=local
# OPENCHAT_USER_INDEX_CANISTER=rrkah-fqaaa-aaaaa-aaaaq-cai
# OPENCHAT_GROUP_INDEX_CANISTER=rno2w-sqaaa-aaaaa-aaacq-cai
# OPENCHAT_BOT_USERNAME=dev_bot
# OPENCHAT_PEM_FILE=/Users/yourname/.config/dfx/identity/default/identity.pem

# Testnet Example:
# OPENCHAT_NETWORK=testnet
# OPENCHAT_USER_INDEX_CANISTER=testnet-user-index-id
# OPENCHAT_GROUP_INDEX_CANISTER=testnet-group-index-id
# OPENCHAT_BOT_USERNAME=test_eliza_bot
# OPENCHAT_SEED_PHRASE="your testnet seed phrase here"

# Production Example:
# OPENCHAT_NETWORK=mainnet
# OPENCHAT_USER_INDEX_CANISTER=rdmx6-jaaaa-aaaah-qcaiq-cai
# OPENCHAT_GROUP_INDEX_CANISTER=bkyz2-fmaaa-aaaah-qcaiq-cai
# OPENCHAT_BOT_USERNAME=eliza_assistant
# OPENCHAT_PRIVATE_KEY=your-production-private-key
# OPENCHAT_RATE_LIMIT_PER_MINUTE=5
# OPENCHAT_RATE_LIMIT_PER_HOUR=50

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 
# 1. Never commit this file with real values to version control
# 2. Use different identities for different environments
# 3. Rotate keys regularly in production
# 4. Store sensitive values in secure environment variable systems
# 5. Use appropriate rate limits to avoid being flagged as spam
# 6. Monitor your bot's behavior and resource usage
#
# =============================================================================